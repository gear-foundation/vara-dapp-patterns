{
  "name": "vara-gasless-server",
  "version": "1.0.0",
  "description": "Vara gasless server — voucher lifecycle management via @gear-js/api",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": ["vara", "gasless", "voucher", "gear", "sails"],
  "license": "MIT",
  "engines": {
    "node": ">=18.x"
  },
  "dependencies": {
    "@gear-js/api": "0.42.0",
    "@polkadot/api": "16.0.1",
    "@polkadot/keyring": "^12.6.2",
    "@polkadot/types": "16.0.1",
    "@polkadot/util": "^12.6.2",
    "@polkadot/util-crypto": "^12.6.2",
    "@polkadot/wasm-crypto": "^7.3.2",
    "body-parser": "^1.20.3",
    "bn.js": "^5.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "sails-js": "0.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
