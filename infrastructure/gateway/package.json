    "@polkadot/types": "16.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "sails-js": "0.4.2",
    "sails-js-parser": "0.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
