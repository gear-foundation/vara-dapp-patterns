# Vara network WebSocket endpoint
NETWORK=wss://testnet.vara.network

# Factory contract (VFT deployer)
FACTORY_CONTRACT_ID=0x...
FACTORY_IDL=<paste full IDL string here or load from file>

# Pool factory contract (DEX pair registry)
POOL_FACTORY_CONTRACT_ID=0x...
POOL_FACTORY_IDL=<paste full IDL string here or load from file>

# Server-side wallet that signs all transactions
WALLET_NAME=gateway-signer
WALLET_MNEMONIC=word1 word2 word3 ... word12

# Optional API key for endpoint protection
API_KEY=

# CORS (comma-separated origins or *)
ALLOWED_ORIGINS=http://localhost:5173,https://myapp.com

# Server
PORT=3000
NODE_ENV=development
